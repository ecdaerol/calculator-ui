{
  "name": "@ecdaerol/calculator-ui",
  "version": "0.2.0",
  "private": true,
  "description": "Shared design tokens, Tailwind preset, and React chrome components for the @ecdaerol calculator suite",
  "license": "MIT",
  "author": "Ecda Erol <ecdaerol@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecdaerol/calculator-ui.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tailwind-preset": {
      "require": "./tailwind-preset.cjs",
      "default": "./tailwind-preset.cjs"
    }
  },
  "files": [
    "dist",
    "tailwind-preset.cjs",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
